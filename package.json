{
  "name": "oil-gas-intelligence-assistant",
  "version": "1.0.0",
  "description": "AI-powered Oil & Gas Opportunity Intelligence Assistant for IBM teams",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "api": "node src/api-server.js",
    "dev": "nodemon src/index.js",
    "dev:api": "nodemon src/api-server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "validate-profile": "node scripts/validate-profile.js",
    "test-profile": "node scripts/test-profile.js",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "format": "prettier --write \"src/**/*.js\"",
    "setup": "node scripts/setup.js"
  },
  "keywords": [
    "oil-gas",
    "intelligence",
    "slack-bot",
    "ai",
    "ibm",
    "watsonx",
    "opportunity-detection"
  ],
  "author": "IBM Bobathon Team",
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "@slack/bolt": "^3.17.0",
    "@slack/web-api": "^6.11.0",
    "axios": "^1.6.0",
    "cheerio": "^1.0.0-rc.12",
    "cors": "^2.8.6",
    "date-fns": "^3.0.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "langchain": "^0.1.0",
    "lodash": "^4.17.21",
    "mongodb": "^6.3.0",
    "node-cron": "^3.0.3",
    "redis": "^4.6.0",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-node": "^11.1.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.0",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/index.js"
    ],
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  }
}
